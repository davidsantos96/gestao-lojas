# Copie para .env.local e ajuste os valores

# URL da API (local ou produção)
VITE_API_URL=http://localhost:3000/api

# Timeout das requisições em ms (opcional)
VITE_API_TIMEOUT=10000

# ─── Empresa / Tenant ──────────────────────────────────────────────────────────
# O empresaId é lido automaticamente do usuário logado (campo empresaId do JWT).
# Este valor abaixo é usado apenas como fallback quando não há sessão ativa,
# por exemplo no reload inicial antes do getMe() retornar.
VITE_EMPRESA_ID=empresa-demo
